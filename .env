# --- Pipeline Mode ---
# Options: json | raw | raw_retry
PIPELINE_MODE=json
MAX_RETRIES=3
# --- LLM Configuration ---
# Set to 1 if using the remote Kaggle/Colab endpoint
USE_REMOTE_MODEL=0
# If using remote model, paste your Ngrok URL here
GEMMA_API_URL=https://your-ngrok-url.ngrok-free.dev
# --- API Keys (leave blank if not using that backend) ---
NVIDIA_API_KEY=
GEMINI_API_KEY=
WANDB_API_KEY=
# --- Local Ollama (default if USE_REMOTE_MODEL=0) ---
# Make sure Ollama is running locally and you have pulled the model:
#   ollama pull gemma4:e2b
